---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Base title="Blog">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Blog</h1>
  <ul class="space-y-8">
    {posts.map((post) => (
      <li>
        <a href={`/blog/${post.slug}`} class="group block">
          <h2 class="text-xl font-semibold text-indigo-600 group-hover:text-indigo-800">
            {post.data.title}
          </h2>
          <time class="text-sm text-gray-400" datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {post.data.description && (
            <p class="mt-1 text-gray-600">{post.data.description}</p>
          )}
        </a>
      </li>
    ))}
  </ul>
</Base>
