---
import Base from '../layouts/Base.astro';
import { readFileSync, readdirSync } from 'fs';
import { dirname, join } from 'path';
import { fileURLToPath } from 'url';
import { marked } from 'marked';
import { computeStats } from '../lib/stats';

interface QuestionResult {
  id: string;
  prompts: string[];
  displayQuestion?: string;
  note?: string;
  results: Array<{
    model: string;
    company?: string;
    runs: number;
    answers: Array<{ value: string; count: number; percent: number }>;
  }>;
}

export async function getStaticPaths() {
  const resultsDir = join(dirname(fileURLToPath(import.meta.url)), '../../../results');
  const results: QuestionResult[] = readdirSync(resultsDir)
    .filter((f) => f.endsWith('.json'))
    .map((f) => JSON.parse(readFileSync(join(resultsDir, f), 'utf8')));
  return results.map((data) => ({
    params: { id: data.id },
    props: { data },
  }));
}

const { data } = Astro.props as { data: QuestionResult };

const renderedNote = data.note ? await marked(data.note) : null;

// Group results by company
const groupMap = new Map<string, typeof data.results>();
for (const r of data.results) {
  const company = r.company ?? 'Other';
  if (!groupMap.has(company)) groupMap.set(company, []);
  groupMap.get(company)!.push(r);
}
const groups = Array.from(groupMap.entries()).sort(([a], [b]) => a.localeCompare(b));

const reserved: Record<string, string> = {
  refusal: '#ef4444',
  hedge:   '#9ca3af',
  other:   '#f59e0b',
};

const palette = [
  '#6366f1', '#10b981', '#8b5cf6',
  '#06b6d4', '#f97316', '#ec4899', '#84cc16', '#14b8a6',
  '#f43f5e', '#a855f7', '#0ea5e9', '#d97706', '#22c55e',
  '#e879f9', '#64748b', '#dc2626',
];

const allValues = new Set<string>();
for (const [, modelResults] of groups) {
  for (const modelResult of modelResults) {
    for (const { value } of modelResult.answers) {
      allValues.add(value);
    }
  }
}

const colorMap = new Map<string, string>();
let ci = 0;
for (const value of allValues) {
  if (reserved[value]) {
    colorMap.set(value, reserved[value]);
  } else {
    colorMap.set(value, palette[ci++ % palette.length]);
  }
}

const stats = computeStats(data.results);

const MUTED = ['hedge', 'refusal', 'other'];
const realAnswers = stats?.macroAnswers.filter((a) => !MUTED.includes(a.value)) ?? [];
const top = realAnswers[0];
const sortedLegend = Array.from(colorMap.entries()).sort(([a], [b]) => {
  const pa = stats?.macroAnswers.find((x) => x.value === a)?.percent ?? 0;
  const pb = stats?.macroAnswers.find((x) => x.value === b)?.percent ?? 0;
  return pb - pa;
});
---

<Base title={data.displayQuestion ?? data.prompts[0]}>
  <div class="mb-6">
    <a href="/" class="text-sm text-indigo-600 hover:underline">← All questions</a>
  </div>

  {data.displayQuestion ? (
    <h1 class="text-2xl font-bold mb-6">{data.displayQuestion}</h1>
  ) : (
    <h1 class="text-2xl font-bold mb-6">{data.prompts[0]}</h1>
  )}

  {stats && (
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 mb-8">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Overview</p>
      {top && (
        <div class="flex items-center gap-3 mb-4 flex-wrap">
          <span
            class="text-sm font-semibold px-3 py-1 rounded-full text-white"
            style={`background-color:${colorMap.get(top.value)}`}
          >{top.value}</span>
          <span class="text-lg font-semibold text-gray-900">{top.percent}%</span>
          <span class="text-sm text-gray-500">
            {stats.agreeing} of {stats.total} model{stats.total !== 1 ? 's' : ''} agree
          </span>
        </div>
      )}
      <div class="flex h-7 rounded overflow-hidden w-full mb-3">
        {stats.macroAnswers.filter(({ percent }) => percent > 0).map(({ value, percent }) => (
          <div
            class="flex items-center justify-center overflow-hidden"
            style={`width:${percent}%;background-color:${colorMap.get(value)}`}
          >
            {percent >= 10 && (
              <span class="text-xs text-white font-medium truncate px-1 select-none">{value} {percent}%</span>
            )}
          </div>
        ))}
      </div>
      <div class="flex flex-wrap gap-x-4 gap-y-1">
        {sortedLegend.map(([value, color]) => {
          const macroEntry = stats.macroAnswers.find((a) => a.value === value);
          return (
            <div class="flex items-center gap-1.5 text-sm text-gray-600">
              <span class="inline-block w-3 h-3 rounded-sm shrink-0" style={`background:${color}`} />
              {value}{macroEntry ? ` · ${macroEntry.percent}%` : ''}
            </div>
          );
        })}
      </div>
    </div>
  )}

  {renderedNote && (
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-xs font-semibold text-amber-700 uppercase tracking-wide mb-2">Author's note</p>
      <div class="prose prose-sm" set:html={renderedNote} />
    </div>
  )}

  <div class="bg-gray-900 rounded-lg mb-6">
    <div class="p-4">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">User message(s)</p>
      <pre class="text-sm text-gray-100 whitespace-pre-wrap font-mono">{data.prompts[0]}</pre>
    </div>
    {data.prompts.length > 1 && (
      <details class="border-t border-gray-700 group">
        <summary class="px-4 py-2 text-xs text-gray-400 cursor-pointer hover:text-gray-200 list-none">
          <span class="group-open:hidden">+ {data.prompts.length - 1} more prompt{data.prompts.length > 2 ? 's' : ''}</span>
          <span class="hidden group-open:inline">hide</span>
        </summary>
        <div class="px-4 pb-4 space-y-3">
          {data.prompts.slice(1).map((p) => (
            <pre class="text-sm text-gray-100 whitespace-pre-wrap font-mono">{p}</pre>
          ))}
        </div>
      </details>
    )}
  </div>

  <div class="space-y-10">
    {groups.map(([company, modelResults]) => (
      <div>
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4 border-b border-gray-100 pb-2">
          {company}
        </h2>
        <div class="space-y-8">
          {modelResults.map((modelResult) => (
            <section>
              <h3 class="text-sm font-semibold text-gray-500 mb-3">
                {modelResult.model}
                <span class="font-normal text-gray-400 ml-1">({modelResult.runs} runs)</span>
              </h3>
              <div class="flex h-7 rounded overflow-hidden w-full">
                {modelResult.answers
                  .filter(({ percent }) => percent > 0)
                  .map(({ value, percent }) => (
                    <div
                      class="flex items-center justify-center overflow-hidden"
                      style={`width: ${percent}%; background-color: ${colorMap.get(value)}`}
                    >
                      {percent >= 10 && (
                        <span class="text-xs text-white font-medium truncate px-1 select-none">
                          {value} {percent}%
                        </span>
                      )}
                    </div>
                  ))
                }
              </div>
            </section>
          ))}
        </div>
      </div>
    ))}
  </div>

</Base>
