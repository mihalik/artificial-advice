---
interface Props {
  title?: string;
  frontmatter?: { title?: string };
}

const { title, frontmatter } = Astro.props;
const pageTitle = title ?? frontmatter?.title ?? 'AI Alignment Report';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle} · AI Alignment Report</title>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">
    <nav class="bg-white border-b border-gray-200 px-6 py-4 flex items-center">
      <a href="/" class="text-lg font-semibold text-indigo-600 hover:text-indigo-800">
        AI Alignment Report
      </a>
      <a href="/blog" class="ml-auto text-sm text-gray-500 hover:text-gray-800">
        Blog
      </a>
      <a href="/methodology" class="pl-6 text-sm text-gray-500 hover:text-gray-800">
        About
      </a>
      <a
        href="https://github.com/mihalik/ai-alignment-report"
        class="pl-6 flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-800"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        mihalik/ai-alignment-report
      </a>
    </nav>
    <main class="max-w-5xl mx-auto px-6 py-10 flex-1 w-full">
      {frontmatter ? (
        <div class="prose prose-gray max-w-3xl">
          <slot />
        </div>
      ) : (
        <slot />
      )}
    </main>
    <footer class="bg-white border-t border-gray-200 px-6 py-6 text-sm text-gray-500">
      <div class="max-w-5xl mx-auto flex flex-wrap items-center gap-4">
        <a href="/blog" class="hover:text-gray-800">Blog</a>
        <a href="/methodology" class="hover:text-gray-800">Methodology</a>
        <a
          href="https://github.com/mihalik/ai-alignment-report"
          class="flex items-center gap-1.5 hover:text-gray-800"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          mihalik/ai-alignment-report
        </a>
      </div>
    </footer>
  </body>
</html>
